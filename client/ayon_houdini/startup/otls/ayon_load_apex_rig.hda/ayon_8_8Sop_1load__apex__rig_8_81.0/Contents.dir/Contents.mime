    parm {
        name    "propname"
        baseparm
        label   "Prop Name"
        export  none
    }
    parm {
        name    "animate"
        baseparm
        label   "Animation"
        export  none
    }
    parm {
        name    "multiprop"
        baseparm
        label   "Import Prop Collection"
        export  none
    }
    groupsimple {
        name    "folder3"
        label   "Control"
        grouptag { "sidefx::switcher" "folder0" }

        parm {
            name    "use_skin"
            baseparm
            label   "Add Skin Control"
            export  none
        }
        parm {
            name    "visible"
            baseparm
            label   "Visible"
            export  none
        }
        parm {
            name    "color"
            baseparm
            label   "Color"
            export  none
        }
        parm {
            name    "shapeoverride"
            baseparm
            label   "Shape"
            export  none
        }
        groupcollapsible {
            name    "folder4"
            label   "Rest Position"
            grouptag { "sidefx::switcher" "folder1" }

            parm {
                name    "t"
                baseparm
                label   "Center"
                export  none
            }
            parm {
                name    "r"
                baseparm
                label   "Rotate"
                export  none
            }
        }

        groupcollapsible {
            name    "folder5"
            label   "Shape Offset"
            grouptag { "sidefx::switcher" "folder2" }

            parm {
                name    "shape_t"
                baseparm
                label   "Shape Center"
                export  none
            }
            parm {
                name    "shape_r"
                baseparm
                label   "Shape Rotate"
                export  none
            }
            parm {
                name    "shape_scale"
                baseparm
                label   "Shape Uniform Scale"
                export  none
            }
        }

    }

    groupcollapsible {
        name    "ragdoll2"
        label   "Ragdoll"
        disablewhen "{ animate > 1 }"
        parmtag { "group_default" "0" }
        parmtag { "sidefx::header_toggle" "enableragdoll" }
        grouptag { "sidefx::switcher" "ragdoll" }

        parm {
            name    "enableragdoll"
            baseparm
            label   "enableragdoll"
            nolabel
            export  none
        }
        parm {
            name    "active"
            baseparm
            label   "Active"
            export  none
        }
        parm {
            name    "convexhull"
            baseparm
            label   "Collision Shape"
            export  none
        }
        parm {
            name    "maxconcavity"
            baseparm
            label   "Max Concavity"
            export  none
        }
        parm {
            name    "treatassolid"
            baseparm
            label   "Treat as Solid"
            export  none
        }
        parm {
            name    "dopolyreduce"
            baseparm
            label   "Reduce Polygons"
            export  none
        }
        parm {
            name    "npts"
            baseparm
            label   "Number of Pieces"
            export  none
        }
        parm {
            name    "displayhull"
            baseparm
            label   "Display Collision Shape"
            joinnext
            export  none
        }
        parm {
            name    "explodedview"
            baseparm
            label   "Exploded View"
            export  none
        }
        parm {
            name    "shapecolor"
            baseparm
            label   "Color"
            export  none
        }
    }

    parm {
        name    "spare_input0"
        label   "Spare Input 0"
        type    oppath
        default { "" }
        help    "Refer to this in expressions as -1, such as: npoints(-1)"
        parmtag { "cook_dependent" "1" }
        parmtag { "opfilter" "!!SOP!!" }
        parmtag { "oprelative" "." }
    }

